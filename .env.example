# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ============================================================================
# MCAT — dados reais (Sprint 0+). Copie para .env e preencha. Não commitar .env.
# ============================================================================

# --- Banco (Supabase / Postgres) ---
DATABASE_URL="postgres://postgres:senha@host:5432/postgres"
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""   # nunca expor no frontend

# --- Câmbio PTAX (API pública do Banco Central, sem chave) ---
BCB_PTAX_BASE="https://olinda.bcb.gov.br/olinda/servico/PTAX/versao/v1/odata"

# --- Roteamento de modelos (Sprint 4) ---
OPENROUTER_API_KEY=""
